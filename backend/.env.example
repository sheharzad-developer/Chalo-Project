# Copy to .env and fill in real values. NEVER commit the real .env.

# Supabase Postgres. Use the IPv4 session pooler (Settings → Database → Connection string).
DATABASE_URL=postgresql+asyncpg://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-1-<REGION>.pooler.supabase.com:5432/postgres
REDIS_URL=redis://localhost:6379/0

SUPABASE_URL=https://<PROJECT_REF>.supabase.co
# Legacy HS256 secret (Settings → JWT Keys). Optional if your project uses ES256 signing keys.
SUPABASE_JWT_SECRET=<supabase jwt secret>

# Optional: only needed if backend routing is switched from OSRM to Google.
GOOGLE_MAPS_KEY=<google maps api key>

# SafePay — from sandbox.getsafepay.com → API Settings
# API key = public key (sec_...); secret key signs the auth header + webhook HMAC.
SAFEPAY_API_KEY=sec_<your-public-merchant-key>
SAFEPAY_SECRET_KEY=<your-secret-key>
# "sandbox" for testing, "production" for live
SAFEPAY_ENV=sandbox
