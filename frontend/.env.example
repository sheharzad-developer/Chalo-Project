# Copy to .env and fill in real values. NEVER commit the real .env.
# EXPO_PUBLIC_* values are bundled into the app — only put client-safe values here
# (publishable/anon key, API URL, env flag). Never a secret/merchant key.

EXPO_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon or publishable key from Supabase dashboard>
# Public URL of the backend (e.g. an https tunnel or deployed host).
EXPO_PUBLIC_API_URL=https://<your-backend-url>
# "sandbox" for testing, "production" for live
EXPO_PUBLIC_SAFEPAY_ENV=sandbox

# Build-time only (injected into native config by app.config.js); not bundled as a client var.
GOOGLE_MAPS_KEY=<your Google Maps API key>
